{
  "name": "hux",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "snapshot": "tsx src/index.ts --print",
    "check": "bun run check:ts && bun run check:server && bun run check:daemon",
    "check:ts": "tsc --noEmit",
    "check:server": "cargo check --manifest-path server/Cargo.toml",
    "check:daemon": "swift build -c release --package-path daemon",
    "build": "bun run build:server && bun run build:daemon && bun run build:client",
    "build:server": "cargo build --release --manifest-path server/Cargo.toml",
    "build:daemon": "swift build -c release --package-path daemon",
    "build:client": "bun build --compile --minify --target=bun --sourcemap=none src/index.ts --outfile hux"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {}
}
